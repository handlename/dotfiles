{
  "env": {
    "CLAUDE_LANGUAGE": "ja"
  },
  "permissions": {
    "allow": [
      "Bash(:*:*)",
      "Edit(**)",
      "Read(**)",
      "WebFetch(domain:*)",
      "mcp__ide__getDiagnostics",
      "mcp__serena__activate_project",
      "mcp__serena__check_onboarding_performed",
      "mcp__serena__create_text_file",
      "mcp__serena__delete_lines",
      "mcp__serena__delete_memory",
      "mcp__serena__execute_shell_command",
      "mcp__serena__find_referencing_code_snippets",
      "mcp__serena__find_referencing_symbols",
      "mcp__serena__find_symbol",
      "mcp__serena__get_active_project",
      "mcp__serena__get_current_config",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__initial_instructions",
      "mcp__serena__insert_after_symbol",
      "mcp__serena__insert_at_line",
      "mcp__serena__insert_before_symbol",
      "mcp__serena__list_dir",
      "mcp__serena__list_memories",
      "mcp__serena__onboarding",
      "mcp__serena__prepare_for_new_conversation",
      "mcp__serena__read_file",
      "mcp__serena__read_memory",
      "mcp__serena__replace_lines",
      "mcp__serena__replace_symbol_body",
      "mcp__serena__restart_language_server",
      "mcp__serena__search_for_pattern",
      "mcp__serena__summarize_changes",
      "mcp__serena__switch_modes",
      "mcp__serena__think_about_collected_information",
      "mcp__serena__think_about_task_adherence",
      "mcp__serena__think_about_whether_you_are_done",
      "mcp__serena__write_memory",
      "mcp__serena__write_memory",
      "mcp__serena__list_memories",
      "mcp__serena__find_file",
      "mcp__context7__get-library-docs",
      "mcp__context7__resolve-library-id"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)"
    ],
    "hooks": {
      "SessionStart": [
        {
          "type": "command",
          "command": "rm -f .claude/.commit-allowed"
        }
      ],
      "PreToolUse": [
        {
          "matcher": "Bash|mcp__acp__Bash|mcp__plugin_serena_serena__execute_shell_command",
          "hooks": [
            {
              "type": "agent",
              "prompt": "You are a safety guard for shell commands. Evaluate whether the following command is dangerous and should be blocked.\n\nCommand context:\n$ARGUMENTS\n\nJudgment principle: Block operations that are IRRECOVERABLE or AFFECT THE ENTIRE SYSTEM. This is an insurance-role hook — minimize false positives and only block clearly dangerous operations. When in doubt, allow.\n\nCategories to check:\n1. Destructive file operations — deletion/overwrite of critical files (.env, config files, lock files, etc.)\n2. Secret information leakage — reading/sending files containing API keys, tokens, SSH keys (e.g. ~/.aws/credentials, ~/.ssh/id_rsa, .env files), OR printing/exposing environment variables that may contain secrets (e.g. echo $API_KEY, printenv SECRET_TOKEN)\n3. External service impact — write/delete requests to external APIs (POST/PUT/DELETE/PATCH to remote URLs). Read-only GET requests are safe.\n4. Destructive git operations — operations where data is irrecoverable. git stash drop, git branch -D are dangerous. git reset --hard is SAFE (recoverable via reflog). git push and git commit are handled by other hooks — do not block them here.\n5. Privilege escalation / system changes — chmod/chown on system files (/etc, /usr, etc.)\n\nIMPORTANT exceptions (do NOT block these):\n- git push, git commit (handled by separate confirm hooks)\n- npm/yarn/pnpm install -g (not destructive)\n- docker rm/stop/kill (containers are ephemeral and recreatable)\n- make, cargo build, go build, npm run (build commands)\n- git reset --hard, git checkout, git rebase (recoverable via reflog)\n- Local file creation/editing in the project directory\n- curl/wget GET requests\n\nRespond with ONLY one of the following JSON objects (no other text):\n{\"ok\": true}\n{\"ok\": false, \"reason\": \"explanation in Japanese\"}"
            },
            {
              "type": "confirm",
              "message": "git push を実行しようとしています。続行しますか？",
              "condition": "command.includes('git push') || command.includes('git') && command.includes('push')"
            },
            {
              "type": "confirm",
              "message": "git commit を実行しようとしています。続行しますか？",
              "condition": "(command.includes('git commit') || (command.includes('git') && command.includes('commit'))) && !require('fs').existsSync('.claude/.commit-allowed')"
            },
            {
              "type": "confirm",
              "message": ".commit-allowed ファイルを操作しようとしています。続行しますか？",
              "condition": "command.includes('.commit-allowed')"
            }
          ]
        },
        {
          "matcher": "Write",
          "hooks": [
            {
              "type": "confirm",
              "message": ".commit-allowed ファイルを操作しようとしています。続行しますか？",
              "condition": "file_path && file_path.includes('.commit-allowed')"
            }
          ]
        },
        {
          "matcher": "Edit|MultiEdit",
          "hooks": [
            {
              "type": "confirm",
              "message": ".commit-allowed ファイルを操作しようとしています。続行しますか？",
              "condition": "file_path && file_path.includes('.commit-allowed')"
            }
          ]
        },
        {
          "matcher": "mcp__plugin_serena_serena__create_text_file",
          "hooks": [
            {
              "type": "confirm",
              "message": ".commit-allowed ファイルを操作しようとしています。続行しますか？",
              "condition": "relative_path && relative_path.includes('.commit-allowed')"
            }
          ]
        }
      ],
      "PostToolUse": [
        {
          "matcher": "Write|Edit|MultiEdit",
          "hooks": [
            {
              "type": "command",
              "command": "~/.claude/hooks/format-code.sh"
            }
          ]
        }
      ]
    }
  },
  "statusLine": {
    "type": "command",
    "command": "npx ccusage@latest statusline"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "serena@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "using-cmux@hummer98-using-cmux": true,
    "oh-my-claudecode@omc": true
  },
  "extraKnownMarketplaces": {
    "datadog-api-claude-plugin": {
      "source": {
        "source": "github",
        "repo": "Datadog/datadog-api-claude-plugin"
      }
    },
    "hummer98-using-cmux": {
      "source": {
        "source": "github",
        "repo": "hummer98/using-cmux"
      }
    },
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "runestone-workflow": {
      "source": {
        "source": "git",
        "url": "https://github.com/handlename/obsidian-plugin-runestone.git"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1753952965497
  }
}
